# Backend environment
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
# Local default is SQLite; for Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/campus
DATABASE_URL=sqlite:///./campus.db

# AI — leave blank to run with the deterministic fallback router (no key needed)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# RAG
CHROMA_PERSIST_DIR=./.chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
